<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayoutTorneos"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F13"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="#8B5CF6" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Skillzone"
                android:textAlignment="center"
                android:textColor="#8B5CF6"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnPerfil"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#FFFFFF"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:paddingTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:layout_constraintBottom_toTopOf="@id/bottomNav">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginHorizontal="20dp"
                app:cardCornerRadius="25dp"
                app:cardBackgroundColor="#2A2A35"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="15dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="#808080"/>

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:hint="Buscar torneo..."
                        android:textColorHint="#808080"
                        android:textColor="#FFFFFF"
                        android:singleLine="true"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Torneos Destacados"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="15dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="20dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:layout_width="280dp"
                        android:layout_height="420dp"
                        android:layout_marginEnd="15dp"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="#2A2A35">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/imgTorneo1"
                                android:layout_width="match_parent"
                                android:layout_height="200dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/torneos"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/tvTitulo1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Copa de Verano"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:layout_margin="15dp"
                                app:layout_constraintTop_toBottomOf="@id/imgTorneo1" />

                            <TextView
                                android:id="@+id/tvInfo1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Premio: 500€\nInscritos: 45/64\nModalidad: 5v5"
                                android:textColor="#B0B0B0"
                                android:textSize="14sp"
                                android:layout_marginHorizontal="15dp"
                                android:layout_marginTop="5dp"
                                app:layout_constraintTop_toBottomOf="@id/tvTitulo1" />

                            <Button
                                android:id="@+id/btnInscribirse1"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="Inscribirse"
                                android:textAllCaps="false"
                                android:backgroundTint="#8B5CF6"
                                android:textColor="#FFFFFF"
                                android:layout_margin="15dp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent" />

                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="280dp"
                        android:layout_height="420dp"
                        android:layout_marginEnd="15dp"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="#2A2A35">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/imgTorneo2"
                                android:layout_width="match_parent"
                                android:layout_height="200dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/torneos"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/tvTitulo2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Liga Profesional"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:layout_margin="15dp"
                                app:layout_constraintTop_toBottomOf="@id/imgTorneo2" />

                            <TextView
                                android:id="@+id/tvInfo2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Premio: 1000€\nInscritos: 12/16\nModalidad: 1v1"
                                android:textColor="#B0B0B0"
                                android:textSize="14sp"
                                android:layout_marginHorizontal="15dp"
                                android:layout_marginTop="5dp"
                                app:layout_constraintTop_toBottomOf="@id/tvTitulo2" />

                            <Button
                                android:id="@+id/btnInscribirse2"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="Inscribirse"
                                android:textAllCaps="false"
                                android:backgroundTint="#8B5CF6"
                                android:textColor="#FFFFFF"
                                android:layout_margin="15dp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent" />

                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1A24"
            app:itemIconTint="#FFFFFF"
            app:itemTextColor="#FFFFFF"
            app:menu="@menu/bottom_menu"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#1A1A24"
        app:itemTextColor="#FFFFFF"
        app:itemIconTint="#8B5CF6"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>